# Copy to /etc/purpledroid/purpledroid.env on the VPS.
#
# For an IP-only test deployment, keep the default wildcard CORS or set the
# exact HTTP origin, for example:
# PURPLEDROID_CORS_ORIGINS=http://107.173.164.160
#
# For a real domain, use:
# PURPLEDROID_CORS_ORIGINS=https://play.example.com

PURPLEDROID_SESSION_PERSIST=1
PURPLEDROID_SESSION_STORE=/var/lib/purpledroid/sessions.json
PURPLEDROID_CORS_ORIGINS=*

# Production should not unlock missions automatically.
PURPLEDROID_UNLOCK_ALL=0
PURPLEDROID_UNLOCK_UNTIL=
